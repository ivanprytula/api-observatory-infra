# Managed by Ansible — do not edit manually.
# Source: infra/ansible/roles/app/templates/env.j2

# Database
DATABASE_URL={{ compose_env.database_url }}

# App
ENVIRONMENT={{ compose_env.environment }}
LOG_LEVEL={{ compose_env.log_level }}
LOG_SQLALCHEMY_LEVEL={{ compose_env.log_sqlalchemy_level }}
LOG_HTTPX_LEVEL={{ compose_env.log_httpx_level }}
LOG_ASYNCIO_LEVEL={{ compose_env.log_asyncio_level }}

# Documentation Authentication
DOCS_USERNAME={{ compose_env.docs_username }}
DOCS_PASSWORD={{ compose_env.docs_password }}

# API Authentication — v1
API_V1_BEARER_TOKEN={{ compose_env.api_v1_bearer_token }}
TOKEN_EXPIRY_HOURS={{ compose_env.token_expiry_hours }}

# API Authentication — v2 (JWT)
JWT_SECRET={{ compose_env.jwt_secret }}
JWT_ALGORITHM={{ compose_env.jwt_algorithm }}
JWT_EXPIRY_MINUTES={{ compose_env.jwt_expiry_minutes }}

# Cache
CACHE_ENABLED={{ compose_env.cache_enabled }}
CACHE_URL={{ compose_env.cache_url }}

# External APIs
OPENAI_API_KEY={{ compose_env.openai_api_key }}

# OpenTelemetry
OTEL_ENABLED={{ compose_env.otel_enabled }}
OTEL_ENDPOINT={{ compose_env.otel_endpoint }}
OTEL_SERVICE_NAME={{ compose_env.otel_service_name }}

# Sentry
SENTRY_ENABLED={{ compose_env.sentry_enabled }}
SENTRY_DSN={{ compose_env.sentry_dsn }}
SENTRY_TRACES_SAMPLE_RATE={{ compose_env.sentry_traces_sample_rate }}

# Background workers
BACKGROUND_WORKERS_ENABLED={{ compose_env.background_workers_enabled }}
BACKGROUND_WORKER_COUNT={{ compose_env.background_worker_count }}
BACKGROUND_WORKER_QUEUE_SIZE={{ compose_env.background_worker_queue_size }}
BACKGROUND_MAX_TRACKED_TASKS={{ compose_env.background_max_tracked_tasks }}
