# Terraform remote state in Azure Storage Account
# Copy to backend.azure.hcl and fill in, then:
#   terraform init -backend-config=backend.azure.hcl
resource_group_name  = "api-observatory-rg"
storage_account_name = "apiobsterraformstate"
container_name       = "tfstate"
key                  = "azure-dev/terraform.tfstate"
